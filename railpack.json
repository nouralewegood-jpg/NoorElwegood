{
  "$schema": "https://railpack.com/schema.json",
  "providers": ["php"],
  "build": {
    "variables": {
      "NIXPACKS_PHP_ROOT_DIR": "/app/public"
    }
  },
  "php": {
    "version": "8.2",
    "extensions": [
      "ctype", "curl", "dom", "fileinfo", "filter", "hash", "mbstring", "openssl", "pcre", "pdo", "session", "tokenizer", "xml", "pdo_mysql", "redis", "gd"
    ]
  }
}